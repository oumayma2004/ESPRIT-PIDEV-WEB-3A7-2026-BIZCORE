<script>
/* ════════════════════════════════════════════════════════════════════
   FLASH PROMO — Polling temps réel (toutes les 2 secondes)
   L'API backend est la seule source de vérité.
   Le frontend n'effectue aucun calcul de prix — c'est le serveur
   qui retourne les données vérifiées.
════════════════════════════════════════════════════════════════════ */
(function () {
    'use strict';

    /* Bannière globale #flash-promo-banner injectée dans le DOM */
    let bannerEl = null;
    function ensureBanner() {
        if (!bannerEl) {
            bannerEl = document.createElement('div');
            bannerEl.id = 'flash-promo-banner';
            bannerEl.innerHTML = `
                <div class="banner-emoji">⚡</div>
                <div class="banner-text" id="fp-banner-text">Promotion flash en cours !</div>
                <div class="banner-cd" id="fp-banner-cd"></div>
            `;
            document.body.appendChild(bannerEl);
        }
        return bannerEl;
    }

    let lastPromos = {};          // cache : { vendorId: { discountPercent, expiresAt, ... } }
    let bannerCdInt = null;
    let bannerVendors = new Set();

    /* ── Applique ou retire la promo sur toutes les cartes produit ── */
    function applyPromos(promos) {
        document.querySelectorAll('.product-price-block').forEach(block => {
            const vendorId     = block.dataset.vendorId;
            const originalPrice= parseFloat(block.dataset.priceEur);
            const promo        = promos[vendorId];
            const card         = block.closest('.product-card');

            const normalDiv    = block.querySelector('.price-normal');
            const promoDiv     = block.querySelector('.promo-price-block');
            const countdownDiv = block.querySelector('.promo-countdown');
            const crossedEl    = block.querySelector('.price-original-crossed');
            const discountedEl = block.querySelector('.price-discounted');
            const pctBadgeEl   = block.querySelector('.promo-pct-badge');

            if (promo && promo.remainingSeconds > 0 && !isNaN(originalPrice)) {
                /* ── Promo active sur ce vendeur ── */
                const pct           = promo.discountPercent;
                // Prix calculé côté serveur via remainingSeconds/discountPercent reçu
                // On recalcule localement uniquement l'affichage (le backend valide)
                const discounted    = Math.round(originalPrice * (1 - pct / 100) * 100) / 100;

                if (normalDiv)    normalDiv.style.display    = 'none';
                if (promoDiv)     promoDiv.style.display     = 'flex';
                if (countdownDiv) countdownDiv.style.display = 'flex';

                if (crossedEl)    crossedEl.textContent   = originalPrice.toFixed(2) + ' €';
                if (discountedEl) discountedEl.textContent = discounted.toFixed(2) + ' €';
                if (pctBadgeEl)   pctBadgeEl.textContent   = '-' + pct + '%';

                countdownDiv.innerHTML = '⏱ ' + promo.remainingSeconds + ' s';

                if (card) card.classList.add('promo-active');

                /* Aussi mettre à jour le data-price-eur pour la devise */
                const priceNormal = block.querySelector('.price-normal');
                if (priceNormal) priceNormal.setAttribute('data-price-eur', originalPrice);

            } else {
                /* ── Pas de promo (ou expirée) ── */
                if (normalDiv)    normalDiv.style.display    = '';
                if (promoDiv)     promoDiv.style.display     = 'none';
                if (countdownDiv) countdownDiv.style.display = 'none';
                if (card)         card.classList.remove('promo-active');
            }
        });

        /* Bannière globale */
        bannerVendors = new Set(Object.keys(promos));
        if (bannerVendors.size > 0) {
            showBanner(promos);
        } else {
            hideBanner();
        }
    }

    /* ── Décrémentation locale du compteur (entre 2 polls) ── */
    function tickLocalCountdowns() {
        document.querySelectorAll('.promo-countdown').forEach(el => {
            const match = el.textContent.match(/(\d+)\ss/);
            if (!match) return;
            let s = parseInt(match[1]) - 1;
            if (s <= 0) {
                // La prochaine synchro serveur vidangera la promo
                el.style.display = 'none';
                const block = el.closest('.product-price-block');
                if (block) {
                    const norm = block.querySelector('.price-normal');
                    const prm  = block.querySelector('.promo-price-block');
                    if (norm) norm.style.display = '';
                    if (prm)  prm.style.display  = 'none';
                    const card = el.closest('.product-card');
                    if (card) card.classList.remove('promo-active');
                }
            } else {
                el.innerHTML = '⏱ ' + s + ' s';
            }
        });
    }

    /* ── Bannière globale ── */
    function showBanner(promos) {
        const b = ensureBanner();
        b.style.display = 'block';

        let maxRemaining = 0;
        let vendorNames  = [];
        Object.values(promos).forEach(p => {
            if (p.remainingSeconds > maxRemaining) maxRemaining = p.remainingSeconds;
            vendorNames.push(p.vendorName);
        });

        const textEl = document.getElementById('fp-banner-text');
        const cdEl   = document.getElementById('fp-banner-cd');
        if (textEl) textEl.textContent = '⚡ Flash Promo : ' + vendorNames.join(', ');
        if (cdEl)   cdEl.textContent   = 'Expire dans ' + maxRemaining + ' s';

        clearInterval(bannerCdInt);
        let rem = maxRemaining;
        bannerCdInt = setInterval(() => {
            rem--;
            if (rem <= 0) {
                clearInterval(bannerCdInt);
                hideBanner();
            } else if (cdEl) {
                cdEl.textContent = 'Expire dans ' + rem + ' s';
            }
        }, 1000);
    }

    function hideBanner() {
        if (bannerEl) bannerEl.style.display = 'none';
        clearInterval(bannerCdInt);
    }

    /* ── Polling toutes les 2 secondes ── */
    async function poll() {
        try {
            const r    = await fetch('/marketplace/api/flash-promos');
            const data = await r.json();
            lastPromos = data.promos || {};
            applyPromos(lastPromos);
        } catch (e) {
            /* réseau indisponible — on ne touche pas à l'affichage existant */
        }
    }

    /* Démarrage immédiat + tick local 1 s + poll serveur 2 s */
    poll();
    setInterval(tickLocalCountdowns, 1000);
    setInterval(poll, 2000);

})();
</script>

<script>
/* ══════════════════════════════════════════════════════════════
   TRADUCTION MARKETPLACE — MyMemory API (appel direct navigateur)
   GET https://api.mymemory.translated.net/get?q=TEXT&langpair=fr|en
   ══════════════════════════════════════════════════════════════ */
(function () {
    'use strict';

    let currentLang = 'fr';

    /* Sélecteurs des textes à traduire */
    const SELECTORS = [
        '.product-card-name',
        '.product-card-desc',
        '.product-cat-badge',
        '.product-card-stock',
        '.bc-empty h3',
        '.bc-empty p',
        '#noResults',
    ];

    /* ── Toggle dropdown ── */
    const btn      = document.getElementById('translate-btn');
    const dropdown = document.getElementById('translate-dropdown');

    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
    });
    document.addEventListener('click', function () {
        dropdown.style.display = 'none';
    });

    /* ── Sélection de langue ── */
    document.querySelectorAll('.lang-item').forEach(function (item) {
        item.addEventListener('click', function () {
            const lang  = this.dataset.lang;
            const label = this.dataset.label;
            dropdown.style.display = 'none';
            if (lang === currentLang) return;
            applyTranslation(lang, label);
        });
    });

    /* ── Collecte les nœuds texte directs des éléments ciblés ── */
    function collectNodes() {
        const seen  = new Set();
        const nodes = [];
        SELECTORS.forEach(function (sel) {
            document.querySelectorAll(sel).forEach(function (el) {
                el.childNodes.forEach(function (child) {
                    if (child.nodeType === Node.TEXT_NODE
                        && child.textContent.trim().length > 0
                        && !seen.has(child)) {
                        seen.add(child);
                        nodes.push(child);
                    }
                });
            });
        });
        return nodes;
    }

    /* ── Overlay de chargement ── */
    const overlay  = document.getElementById('translate-overlay');
    const progress = document.getElementById('translate-progress');

    function showOverlay(msg) {
        overlay.style.display = 'flex';
        progress.textContent  = msg || '';
    }
    function hideOverlay() {
        overlay.style.display = 'none';
    }

    /* ── Traduit un tableau de textes via API PHP interne ── */
    async function translateBatch(textsArray, sourceLang, targetLang) {
        if (!textsArray || textsArray.length === 0) return [];
        
        try {
            const resp = await fetch('/marketplace/api/translate-batch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ texts: textsArray, source_lang: sourceLang, target_lang: targetLang })
            });

            if (!resp.ok) return textsArray;
            const json = await resp.json();
            
            return json.translatedTexts || textsArray;
        } catch (e) {
            console.error('Translation batch error:', e);
            return textsArray;
        }
    }

    /* ── Applique la traduction sur toute la page en parallèle ── */
    async function applyTranslation(targetLang, label) {
        const nodes = collectNodes();
        if (!nodes.length) return;

        /* Sauvegarder les originaux une seule fois */
        nodes.forEach(function (n) {
            if (!n._origText) n._origText = n.textContent;
        });

        /* Retour au français → restauration immédiate, sans appel API */
        if (targetLang === 'fr') {
            nodes.forEach(function (n) { n.textContent = n._origText; });
            document.documentElement.dir = 'ltr';
            setActive(targetLang, label);
            currentLang = 'fr';
            return;
        }

        showOverlay('Traduction ultra-rapide en cours…');

        try {
            // Requêtes en lot pour être beaucoup plus rapide
            const batchSize = 40; // On peut envoyer plus de textes d'un coup
            let translatedCount = 0;

            for (let i = 0; i < nodes.length; i += batchSize) {
                const batchNodes = nodes.slice(i, i + batchSize);
                const originalTexts = batchNodes.map(n => n._origText);
                
                const translatedTexts = await translateBatch(originalTexts, 'fr', targetLang);
                
                batchNodes.forEach((n, index) => {
                    if(translatedTexts[index]) {
                        n.textContent = translatedTexts[index];
                    }
                });
                
                translatedCount += batchNodes.length;
                progress.textContent = translatedCount + ' / ' + nodes.length + ' éléments traduits…';
            }

            document.documentElement.dir = (targetLang === 'ar') ? 'rtl' : 'ltr';
            setActive(targetLang, label);
            currentLang = targetLang;

        } catch (err) {
            console.error('Traduction échouée :', err);
        } finally {
            hideOverlay();
        }
    }

    /* ── Met à jour le bouton & l'item actif ── */
    function setActive(lang, label) {
        document.getElementById('translate-label').textContent = label || lang;
        document.querySelectorAll('.lang-item').forEach(function (li) {
            li.classList.toggle('lang-active', li.dataset.lang === lang);
        });
    }

})();

/* ══════════════════════════════════════════════════════════════
   CONVERTISSEUR DE DEVISES API
   ══════════════════════════════════════════════════════════════ */
(function() {
    const curBtn      = document.getElementById('currency-btn');
    const curDropdown = document.getElementById('currency-dropdown');
    let rates = null;
    let currentCurrency = 'EUR';

    if(!curBtn) return;

    curBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        curDropdown.style.display = curDropdown.style.display === 'none' ? 'block' : 'none';
        document.getElementById('translate-dropdown').style.display = 'none'; // Close other drop
    });
    
    document.addEventListener('click', () => { curDropdown.style.display = 'none'; });

    async function fetchRates() {
        if(rates) return rates;
        try {
            // Appeler l'API PHP interne
            const response = await fetch('/marketplace/api/currency-rates');
            const data = await response.json();
            if(data && data.rates) rates = data.rates;
        } catch(e) {
            console.error('Erreur API Devises PHP', e);
        }
        return rates;
    }

    document.querySelectorAll('.currency-item').forEach(item => {
        item.addEventListener('click', async function() {
            const targetCurrency = this.dataset.currency;
            const symbol = this.dataset.symbol;
            const flag = this.dataset.flag;
            
            curDropdown.style.display = 'none';
            if (targetCurrency === currentCurrency) return;

            document.querySelectorAll('.currency-item').forEach(li => li.classList.remove('currency-active'));
            this.classList.add('currency-active');
            
            document.getElementById('currency-label').textContent = `${targetCurrency} (${symbol})`;
            document.getElementById('currency-flag').textContent = flag;

            const fetchedRates = await fetchRates();
            if (!fetchedRates) {
                alert("Impossible de charger les taux de change.");
                return;
            }

            const rate = fetchedRates[targetCurrency] || 1;
            
            // Mise à jour de tous les prix
            document.querySelectorAll('.product-card-price').forEach(priceEl => {
                const basePriceEur = parseFloat(priceEl.getAttribute('data-price-eur'));
                if (!isNaN(basePriceEur)) {
                    let newPrice = basePriceEur * rate;
                    // Format joli: max 2 decimales
                    newPrice = newPrice.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 });
                    
                    // Format position du symbole selon devise (dt/dh devant, €/$/£ après ou avant)
                    if(['USD', 'GBP', 'CAD', 'JPY', 'CNY', 'SAR'].includes(targetCurrency)) {
                        priceEl.textContent = `${symbol} ${newPrice}`;
                    } else {
                        priceEl.textContent = `${newPrice} ${symbol}`;
                    }
                }
            });

            currentCurrency = targetCurrency;
        });
    });
})();
</script>
{% endblock %}
