{# ─────────────────────────────────────────────────────────────────────────
   Notification Bell Component — 100% static (no API calls)
   Shows a bell icon with unread count badge in the topbar.
   Visible only for non-admin users.
───────────────────────────────────────────────────────────────────────── #}
{% if app.user and not is_granted('ROLE_ADMIN') %}
<div class="notif-bell-wrapper" id="notifBellWrapper" style="position:relative;">

    {# Bell button #}
    <button id="notifBellBtn"
            onclick="toggleNotifDropdown()"
            title="Notifications"
            style="
                width:36px;height:36px;border-radius:50%;
                background:#f3f4f6;border:none;
                display:flex;align-items:center;justify-content:center;
                color:#6b7280;font-size:15px;cursor:pointer;
                transition:background 0.2s;position:relative;
            "
            onmouseover="this.style.background='#e5e7eb'"
            onmouseout="this.style.background='#f3f4f6'">
        <i class="far fa-bell"></i>
        <span id="notifBadge" style="
            position:absolute;top:-4px;right:-4px;
            background:#ef4444;color:#fff;
            font-size:9px;font-weight:700;
            min-width:16px;height:16px;border-radius:50%;
            display:flex;align-items:center;justify-content:center;
            border:2px solid #fff;
        ">1</span>
    </button>

    {# Dropdown panel #}
    <div id="notifDropdown" style="
        position:absolute;top:46px;right:0;
        width:340px;background:#fff;
        border-radius:12px;
        box-shadow:0 8px 32px rgba(0,0,0,0.18);
        border:1px solid #e5e7eb;
        z-index:10000;display:none;
        overflow:hidden;
        animation:slideDownNotif 0.2s ease;
    ">
        {# Header #}
        <div style="
            padding:14px 18px;
            border-bottom:1px solid #f3f4f6;
            display:flex;align-items:center;
            justify-content:space-between;
        ">
            <span style="font-weight:700;font-size:13px;color:#111827;">
                <i class="far fa-bell" style="color:#20c997;margin-right:6px;"></i>
                Notifications
            </span>
            <button onclick="markAllNotificationsRead()" style="
                font-size:11px;color:#6b7280;
                background:none;border:none;cursor:pointer;
                padding:4px 8px;border-radius:6px;
                transition:background 0.2s;
            " onmouseover="this.style.background='#f3f4f6'"
               onmouseout="this.style.background='none'">
                Tout marquer lu
            </button>
        </div>

        {# Static notification list #}
        <div id="notifList" style="max-height:360px;overflow-y:auto;">

            {# Notification 1 — unread #}
            <div class="notif-item" data-read="0"
                 onclick="markOneRead(this)"
                 style="
                     padding:12px 18px;border-bottom:1px solid #f9fafb;
                     background:#f0fdf4;cursor:pointer;transition:background 0.15s;
                     display:flex;gap:12px;align-items:flex-start;
                 "
                 onmouseover="this.style.background='#f9fafb'"
                 onmouseout="if(this.dataset.read==='0')this.style.background='#f0fdf4';else this.style.background='#fff';">
                <div style="
                    width:32px;height:32px;border-radius:50%;
                    background:#10b98122;flex-shrink:0;
                    display:flex;align-items:center;justify-content:center;
                ">
                    <i class="fas fa-calendar-check" style="color:#10b981;font-size:13px;"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:12px;color:#374151;font-weight:600;line-height:1.4;">
                        Votre réservation avec Ahmed Ben Ali pour le 15/04/2026 a bien été confirmée.
                    </div>
                    <div style="font-size:10px;color:#9ca3af;margin-top:3px;">il y a 2 heures</div>
                </div>
                <div class="notif-unread-dot" style="width:8px;height:8px;border-radius:50%;background:#10b981;flex-shrink:0;margin-top:4px;"></div>
            </div>

            {# Notification 2 — read #}
            <div class="notif-item" data-read="1"
                 onclick="markOneRead(this)"
                 style="
                     padding:12px 18px;border-bottom:1px solid #f9fafb;
                     background:#fff;cursor:pointer;transition:background 0.15s;
                     display:flex;gap:12px;align-items:flex-start;
                 "
                 onmouseover="this.style.background='#f9fafb'"
                 onmouseout="this.style.background='#fff'">
                <div style="
                    width:32px;height:32px;border-radius:50%;
                    background:#3b82f622;flex-shrink:0;
                    display:flex;align-items:center;justify-content:center;
                ">
                    <i class="fas fa-info-circle" style="color:#3b82f6;font-size:13px;"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:12px;color:#374151;font-weight:400;line-height:1.4;">
                        Rappel : séance de coaching demain à 10h avec Leila Chahed.
                    </div>
                    <div style="font-size:10px;color:#9ca3af;margin-top:3px;">il y a 1 jour</div>
                </div>
            </div>

            {# Notification 3 — read #}
            <div class="notif-item" data-read="1"
                 onclick="markOneRead(this)"
                 style="
                     padding:12px 18px;border-bottom:1px solid #f9fafb;
                     background:#fff;cursor:pointer;transition:background 0.15s;
                     display:flex;gap:12px;align-items:flex-start;
                 "
                 onmouseover="this.style.background='#f9fafb'"
                 onmouseout="this.style.background='#fff'">
                <div style="
                    width:32px;height:32px;border-radius:50%;
                    background:#ef444422;flex-shrink:0;
                    display:flex;align-items:center;justify-content:center;
                ">
                    <i class="fas fa-calendar-times" style="color:#ef4444;font-size:13px;"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:12px;color:#374151;font-weight:400;line-height:1.4;">
                        Votre réservation du 10/04/2026 a été annulée.
                    </div>
                    <div style="font-size:10px;color:#9ca3af;margin-top:3px;">il y a 3 jours</div>
                </div>
            </div>

        </div>

        {# Footer #}
        <div style="
            padding:10px 18px;border-top:1px solid #f3f4f6;
            text-align:center;
        ">
            <span style="font-size:11px;color:#9ca3af;">
                Affichage des dernières notifications
            </span>
        </div>
    </div>
</div>

<style>
@keyframes slideDownNotif {
    from { opacity:0; transform:translateY(-8px); }
    to   { opacity:1; transform:translateY(0); }
}
</style>

<script>
// ── Notification Bell JS — static (no API calls) ─────────────────────────

let notifOpen = false;

function toggleNotifDropdown() {
    const dropdown = document.getElementById('notifDropdown');
    notifOpen = !notifOpen;
    dropdown.style.display = notifOpen ? 'block' : 'none';
}

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
    const wrapper = document.getElementById('notifBellWrapper');
    if (wrapper && !wrapper.contains(e.target)) {
        document.getElementById('notifDropdown').style.display = 'none';
        notifOpen = false;
    }
});

// Mark a single notification as read (pure JS, no fetch)
function markOneRead(element) {
    if (element.dataset.read === '1') return;
    element.dataset.read = '1';
    element.style.background = '#fff';
    element.querySelector('div[style*="font-weight"]').style.fontWeight = '400';
    var dot = element.querySelector('.notif-unread-dot');
    if (dot) dot.remove();
    updateStaticBadge();
}

// Mark all notifications as read (pure JS, no fetch)
function markAllNotificationsRead() {
    document.querySelectorAll('.notif-item[data-read="0"]').forEach(function(el) {
        markOneRead(el);
    });
}

// Update badge count based on unread items in DOM
function updateStaticBadge() {
    var unread = document.querySelectorAll('.notif-item[data-read="0"]').length;
    var badge = document.getElementById('notifBadge');
    if (!badge) return;
    if (unread > 0) {
        badge.textContent = unread;
        badge.style.display = 'flex';
    } else {
        badge.style.display = 'none';
    }
}

// Add a new notification to the bell dropdown dynamically (no DB)
function refreshNotificationBell(message, type) {
    if (!message) return;
    var list = document.getElementById('notifList');
    if (!list) return;

    var icons = {
        reservation: { icon: 'fa-calendar-check', color: '#10b981' },
        annulation:  { icon: 'fa-calendar-times',  color: '#ef4444' },
        info:        { icon: 'fa-info-circle',      color: '#3b82f6' }
    };
    var meta = icons[type] || icons.reservation;

    var item = document.createElement('div');
    item.className = 'notif-item';
    item.dataset.read = '0';
    item.onclick = function() { markOneRead(this); };
    item.style.cssText = 'padding:12px 18px;border-bottom:1px solid #f9fafb;background:#f0fdf4;cursor:pointer;transition:background 0.15s;display:flex;gap:12px;align-items:flex-start;';
    item.onmouseover = function() { this.style.background = '#f9fafb'; };
    item.onmouseout = function() { if(this.dataset.read==='0') this.style.background='#f0fdf4'; else this.style.background='#fff'; };
    item.innerHTML = '<div style="width:32px;height:32px;border-radius:50%;background:' + meta.color + '22;flex-shrink:0;display:flex;align-items:center;justify-content:center;"><i class="fas ' + meta.icon + '" style="color:' + meta.color + ';font-size:13px;"></i></div>'
        + '<div style="flex:1;min-width:0;"><div style="font-size:12px;color:#374151;font-weight:600;line-height:1.4;">' + message + '</div><div style="font-size:10px;color:#9ca3af;margin-top:3px;">À l\'instant</div></div>'
        + '<div class="notif-unread-dot" style="width:8px;height:8px;border-radius:50%;background:#10b981;flex-shrink:0;margin-top:4px;"></div>';

    list.insertBefore(item, list.firstChild);
    updateStaticBadge();
}
</script>
{% endif %}
